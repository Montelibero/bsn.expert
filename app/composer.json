{
  "name": "mtl/bsn_viewer",
  "description": "Montelibero blockchain social network explorer",
  "license": "CC0-1.0",
  "require": {
    "php": ">=8.5",
    "ext-apcu": "*",
    "ext-bcmath": "*",
    "ext-curl": "*",
    "ext-gd": "*",
    "ext-intl": "*",
    "ext-memcached": "*",
    "ext-mongodb": "*",
    "vlucas/phpdotenv": "^5.6",
    "twig/twig": "^3.10",
    "pecee/simple-router": "^5.4",
    "guzzlehttp/guzzle": "^7.12.1",
    "phpseclib/phpseclib": "^3.0.54",
    "soneso/stellar-php-sdk": "^1.7.1",
    "splitbrain/php-qrcode": "^0.1.0",
    "league/uri": "^7.4",
    "symfony/translation": "^7.2",
    "symfony/twig-bridge": "^7.2",
    "symfony/yaml": "^7.2",
    "php-di/php-di": "^7.0",
    "endroid/qr-code": "^6.0",
    "chillerlan/php-qrcode": "^5.0",
    "erusev/parsedown": "^1.8"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.2",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Montelibero\\BSN\\": "classes/Montelibero/BSN/"
    }
  },
  "scripts": {
    "test": [
      "@test:bsn",
      "@test:session",
      "@test:auth",
      "@test:crowd",
      "@test:markdown",
      "@test:grist"
    ],
    "test:bsn": [
      "php tests/BsnAtomicReloadTest.php"
    ],
    "test:session": [
      "php tests/RequestSessionLazyTest.php"
    ],
    "test:auth": [
      "php tests/LoginControllerFailClosedTest.php",
      "php tests/LoginControllerSignatureWeightsTest.php",
      "php tests/LoginControllerSessionBindingTest.php",
      "php tests/LoginControllerChallengeValidationTest.php",
      "php tests/LoginControllerUnfundedAccountTest.php"
    ],
    "test:crowd": [
      "php tests/CrowdAccessTest.php",
      "php tests/CrowdCsrfTest.php"
    ],
    "test:markdown": [
      "php tests/MarkdownRendererTest.php"
    ],
    "test:grist": [
      "php tests/GristWebhookAccessTest.php"
    ],
    "lint:php": [
      "@php tools/ci/php-lint.php"
    ],
    "lint:twig": [
      "@php tests/TwigSyntaxTest.php"
    ],
    "analyse:php": [
      "phpstan analyse --no-progress --memory-limit=1G"
    ],
    "security:audit": [
      "composer audit --locked --no-dev"
    ],
    "smoke:routes": [
      "@php tools/ci/route-smoke.php"
    ],
    "check": [
      "@lint:php",
      "@lint:twig",
      "@analyse:php",
      "@test",
      "@security:audit"
    ]
  }
}
