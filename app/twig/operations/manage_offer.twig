<ul>
    {% if op.data.exchange_amount and op.data.target_amount %}
        <li>{{ 'transactions.operations.fields.exchange'|trans }}:
            {% include 'amount.twig' with {value: op.data.exchange_amount} only %}
            {{ include('token_link.twig', {token: op.data.selling}, with_context = false) }}
        </li>
        <li>{{ 'transactions.operations.fields.exchange_for'|trans }}:
            {% include 'amount.twig' with {value: op.data.target_amount} only %}
            {{ include('token_link.twig', {token: op.data.buying}, with_context = false) }}
        </li>
    {% endif %}
    {% if op.data.direct_rate %}
        <li>{{ 'transactions.operations.fields.direct_rate'|trans }}:
            {% include 'amount.twig' with {value: op.data.direct_rate} only %}
            {{ op.data.selling_code }} {{ 'transactions.operations.fields.per'|trans }} {{ op.data.buying_code }}
        </li>
    {% endif %}
    {% if op.data.reverse_rate %}
        <li>{{ 'transactions.operations.fields.reverse_rate'|trans }}:
            ≈{% include 'amount.twig' with {value: op.data.reverse_rate} only %}
            {{ op.data.buying_code }} {{ 'transactions.operations.fields.per'|trans }} {{ op.data.selling_code }}
        </li>
    {% endif %}
    {% if op.data.offer_id %}
        <li>{{ 'transactions.operations.fields.offer_id'|trans }}: {{ op.data.offer_id }}</li>
    {% endif %}
</ul>
