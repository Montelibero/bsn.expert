<ul>
    <li>{{ 'transactions.operations.fields.from'|trans }}:
        {{ include('account_link.twig', {data: op.data.from}, with_context = false) }}
    </li>
    <li>{{ 'transactions.operations.fields.to'|trans }}:
        {{ include('account_link.twig', {data: op.data.to}, with_context = false) }}
    </li>
    {% set source_asset = op.data.source_asset %}
    {% set dest_asset = op.data.dest_asset %}
    <li>{{ 'transactions.operations.path_payment.send'|trans }}:
        {% include 'amount.twig' with {value: op.data.source_amount} only %}
        {{ include('token_link.twig', {token: source_asset}, with_context = false) }}
        {% if op.data.source_max %}
            ({{ 'transactions.operations.fields.limit'|trans }} {{ op.data.source_max }})
        {% endif %}
    </li>
    <li>{{ 'transactions.operations.path_payment.receive'|trans }}:
        {% include 'amount.twig' with {value: op.data.dest_amount} only %}
        {{ include('token_link.twig', {token: dest_asset}, with_context = false) }}
        {% if op.data.destination_min %}
            ({{ 'transactions.operations.fields.min_amount'|trans }} {{ op.data.destination_min }})
        {% endif %}
    </li>
    {% if op.data.path %}
        <li>{{ 'transactions.operations.path_payment.path'|trans }}:
            {% for asset in op.data.path %}
                {{ include('token_link.twig', {token: asset}, with_context = false) }}
                {% if not loop.last %} → {% endif %}
            {% endfor %}
        </li>
    {% endif %}
</ul>
