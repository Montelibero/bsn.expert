<script>
    $(function () {
        $(".js-refresh-crowd-snapshot-form").on("submit", function () {
            const button = $(this).find(".js-refresh-crowd-snapshot");
            if (button.prop("disabled")) {
                return false;
            }

            button.prop("disabled", true).addClass("is-loading");
        });
    });
</script>

{% if refresh and refresh.status == 'fallback' %}
    <div class="notification is-warning">
        {{ 'crowd_snapshot_box.refresh.fallback'|trans }}
    </div>
{% endif %}

{% if snapshot and snapshot.warning %}
    <div class="notification is-warning">
        {{ 'crowd_snapshot_box.warning'|trans }}<br>
        <code>{{ snapshot.warning }}</code>
    </div>
{% endif %}

{% if snapshot and refresh %}
    <div class="box">
        <div class="columns is-vcentered">
            <div class="column">
                <div class="field is-grouped is-grouped-multiline mb-0">
                    <div class="control">
                        <span class="tag {% if snapshot.is_fresh %}is-success{% elseif snapshot.is_stale_cache %}is-danger{% else %}is-warning{% endif %}">
                            {% if snapshot.is_fresh %}
                                {{ 'crowd_snapshot_box.source_live'|trans }}
                            {% else %}
                                {{ 'crowd_snapshot_box.source_cache'|trans }}
                            {% endif %}
                        </span>
                    </div>

                    <div class="control">
                        <div class="tags has-addons mb-0">
                            <span class="tag is-dark">{{ 'crowd_snapshot_box.collected_at'|trans }}</span>
                            <span class="tag is-info" {% if snapshot.fetched_at %}title="{{ snapshot.fetched_at|date('d.m.Y H:i', 'UTC') }} UTC"{% endif %}>
                                {{ snapshot.fetched_at|period }}
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="column is-narrow">
                {% if refresh.can_refresh and refresh.action and refresh.code_param_name and refresh.code %}
                    <form method="get" action="{{ refresh.action }}" class="js-refresh-crowd-snapshot-form">
                        <input type="hidden" name="{{ refresh.code_param_name }}" value="{{ refresh.code }}">
                        <button type="submit" class="button is-link is-small js-refresh-crowd-snapshot">
                            {{ 'crowd_snapshot_box.refresh.button'|trans }}
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>
{% endif %}
