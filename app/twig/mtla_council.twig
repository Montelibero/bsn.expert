{% extends "page.twig" %}

{% block title %}{{ 'mtla_council_page.header'|trans }}{% endblock %}

{% block breadcrumbs %}
    <li><a href="/" aria-current="page">{{ 'common.short_name'|trans }}</a></li>
    <li><a href="/mtla/" aria-current="page">{{ 'nav.mtla'|trans }}</a></li>
    <li class="is-active"><a href="#" aria-current="page">{{ 'nav.council'|trans }}</a></li>
{% endblock %}


{% block content %}
    <script>
        $(function () {
            $(".table").tablesorter();
        });
    </script>
    <style>
        .delegation_tree li > ul {
            margin-left: 2em;
        }
    </style>

    <h1 class="title">{{ 'mtla_council_page.header'|trans }}</h1>

    {% if delegation_tree %}
        {% macro renderDelegationTree(tree, level, council_member_limit) %}
            <ul>
                {% for node in tree %}
                    <li>
                        {% if node.show_ready_to_council %}🙋{% endif %}
                        {% if node.show_council_outdated %}🙅{% endif %}
                        {% if node.candidate_index %}<span class="tag {{ node.candidate_index <= council_member_limit ? 'is-primary' : 'is-info' }}">{{ node.candidate_index }}</span>{% endif %}
                        {% if node.is_council %}🏛️{% endif %}
                        {{ include('account_link.twig', {data: node}, with_context = false) }}
                        <span class="has-text-dark">
                        {{ node.own_token_amount }} + {{ node.delegated_token_amount }} =
                        {{ node.own_token_amount + node.delegated_token_amount }}
                        </span>
                        {% if node.delegated is not empty %}
                            {{ _self.renderDelegationTree(node.delegated, level + 1, council_member_limit) }}
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        {% endmacro %}

        <div class="block delegation_tree">
        {{ _self.renderDelegationTree(delegation_tree, 0, council_member_limit) }}
        </div>
    {% endif %}

    {% if council_update %}
        <div class="block">
            <h2 class="title is-4">{{ 'mtla_council_page.update.title'|trans }}</h2>
            <div class="notification is-info">
                <p>{{ 'mtla_council_page.update.operations_count'|trans({'%value%': council_update.operations_count}) }}</p>
                <p>{{ 'mtla_council_page.update.updated_accounts_count'|trans({'%value%': council_update.updated_accounts|length}) }}</p>
                {% if council_update.signers_count != council_member_limit %}
                    <p>{{ 'mtla_council_page.update.signers_count'|trans({'%value%': council_update.signers_count}) }}</p>
                {% endif %}
                <p>
                    {{ 'mtla_council_page.update.threshold'|trans }}:
                    <span class="is-family-monospace">
                        {{ council_update.current_threshold ?? '?' }} → {{ council_update.new_threshold }}
                    </span>
                </p>
            </div>
            {% if council_update.main_account_changes %}
                <h3 class="title is-5">{{ 'mtla_council_page.update.main_account_changes_title'|trans }}</h3>
                <ul class="block">
                    {% for change in council_update.main_account_changes %}
                        <li>
                            <span aria-hidden="true">{{ change.emoji }}</span>
                            {{ include('account_link.twig', {data: change}, with_context = false) }}
                            <span class="is-family-monospace">{{ change.old_weight }} → {{ change.new_weight }}</span>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}
            {{ council_update.signing_form|raw }}
        </div>
    {% elseif council_update_error %}
        <div class="notification is-warning">
            {{ 'mtla_council_page.update.error'|trans({'%error%': council_update_error}) }}
        </div>
    {% endif %}

{% endblock %}
