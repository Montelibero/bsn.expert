<html lang="{{ app_locale|default('en')|e('html_attr') }}" class="has-navbar-fixed-top">
<head>
    <title>{% block title %}{% endblock %} — BSN viewer</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {% if og_title %}
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content="{{ 'common.full_name'|trans }}" />
    <meta property="og:image" content="https://bsn.mtla.me/images/og_title_common.png" />
    <meta property="og:title" content="{{ og_title }}" />
    {%  if og_url %}
        <meta property="og:url" content="https://bsn.mtla.me{{ og_url }}" />
    {% endif %}
    {%  if og_description %}
        <meta property="og:description" content="{{ og_description }}" />
    {% endif %}
    {% endif %}
    <script src="{{ asset_url('/jquery-3.7.1.min.js') }}"></script>
    <script src="{{ asset_url('/jquery.tablesorter.min.js') }}"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bulma@1.0.2/css/bulma.min.css">
    {% include 'fontawesome_link.twig' ignore missing %}
    <link rel="stylesheet" href="{{ asset_url('/style.css') }}">
    <script src="{{ asset_url('/script.js') }}" defer></script>
    {% block head %}{% endblock %}
</head>

<body>
<nav class="navbar is-fixed-top" role="navigation" aria-label="main navigation">
    <div class="navbar-brand">
        <a class="navbar-item has-background-primary has-text-black" href="/">
            {{ 'common.short_name'|trans }}
        </a>
        {% set current_id = current_user.currentAccountId %}

        <a
            class="navbar-item current-account-navbar-item"
            href="/who_are_you?return_to={{ server.REQUEST_URI|url_encode }}"
            data-current-account-modal-trigger
            data-current-account-modal-url="/who_are_you/modal?return_to={{ server.REQUEST_URI|url_encode }}"
        >
            {% if current_id %}
            <i class="fa-solid fa-user" aria-hidden="true"></i>
            {% endif %}
            <span class="current-account-navbar-label">
            {% if current_id %}
            {% set current_account = current_user.getCurrentAccount %}
            {{ current_contacts.getContactName(current_account) ?: current_account.getName[0]|default(null) ?: current_account.getShortId }}
            {% else %}
            {{ 'nav.current_account_unknown'|trans }}
            {% endif %}
            </span>
        </a>
        {% include 'navbar_search_dropdown.twig' with { navbar_search_item_classes: 'is-hidden-desktop navbar-search-brand-item' } %}
        <a class="navbar-burger" role="button" aria-label="menu" aria-expanded="false">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
        </a>
    </div>
    <div class="navbar-menu">
        <div class="navbar-start">

            <div class="navbar-item has-dropdown is-hoverable">
                <a class="navbar-link" href="/">
                    <i class="fa-regular fa-rectangle-list"></i>
                    {{ 'nav.explorer'|trans }}
                </a>
                <div class="navbar-dropdown">
                    <a class="navbar-item" href="/accounts/">
                        {{ 'nav.accounts'|trans }}
                    </a>
                    <a class="navbar-item" href="/tags/">
                        {{ 'nav.tags'|trans }}
                    </a>
                    <a class="navbar-item" href="/tokens/">
                        {{ 'nav.tokens'|trans }}
                    </a>
                    <a class="navbar-item" href="/documents/">
                        {{ 'nav.documents'|trans }}
                    </a>
                    <a class="navbar-item" href="/transactions/">
                        {{ 'nav.transactions'|trans }}
                    </a>
                </div>
            </div>

            <div class="navbar-item has-dropdown is-hoverable">
                <a class="navbar-link" href="/editor/">
                    <i class="fa-regular fa-square-check"></i>
                    {{ 'nav.editor'|trans }}
                </a>
                <div class="navbar-dropdown">
                    <a class="navbar-item" href="/editor/">
                        {{ 'nav.tags'|trans }}
                    </a>
                    <a class="navbar-item" href="/editor/profile">
                        {{ 'nav.profile'|trans }}
                    </a>
                </div>
            </div>

            <div class="navbar-item has-dropdown is-hoverable">
                <a class="navbar-link" href="/tools/">
                    <i class="fa-solid fa-screwdriver"></i>
                    {{ 'nav.tools.title'|trans }}
                </a>
                <div class="navbar-dropdown">
                    <a class="navbar-item" href="/graph">
                        {{ 'nav.graph'|trans }}
                    </a>
                    <hr class="navbar-divider">
                    <a class="navbar-item" href="/tools/multisig">
                        {{ 'nav.tools.multisig'|trans }}
                    </a>
                    <a class="navbar-item" href="/tools/asset_swap">
                        {{ 'nav.tools.asset_swap'|trans }}
                    </a>
                    <a class="navbar-item" href="/tools/swap">
                        {{ 'nav.tools.swap'|trans }} [beta]
                    </a>
                    <a class="navbar-item" href="/tools/migration">
                        {{ 'nav.tools.migration'|trans }}
                    </a>
                    <a class="navbar-item" href="/tools/close_trustlines">
                        {{ 'nav.tools.close_trustlines'|trans }}
                    </a>
                    <a class="navbar-item" href="/tools/orders">
                        {{ 'nav.tools.orders'|trans }}
                    </a>
                    <a class="navbar-item" href="/tools/timetoken">
                        {{ 'nav.tools.timetoken'|trans }}
                    </a>
                    <a class="navbar-item" href="/tools/percent_pay">
                        {{ 'nav.tools.percent_pay'|trans }}
                    </a>
                    <a class="navbar-item" href="/tools/xdr2lab">
                        {{ 'nav.tools.xdr2lab'|trans }}
                    </a>
                    {% if current_user.isImpactActivist %}
                        <hr class="navbar-divider">
                        <a class="navbar-item" href="/tools/mtla/membership_distribution">
                            Выдача токенов участия
                        </a>
                        <a class="navbar-item" href="/tools/mtla/decision_transactions">
                            Подготовка транзакций решения
                        </a>
                        <a class="navbar-item" href="/tools/mtla/send_time_tokens">
                            Рассылка тайм-токенов
                        </a>
                        <a class="navbar-item" href="/tools/mtla/rp_exclusion">
                            Исключение из РП
                        </a>
                    {% endif %}
                </div>
            </div>

            <div class="navbar-item has-dropdown is-hoverable">
                <a class="navbar-link" href="/mtla">
                    <i class="fa-regular fa-building"></i>
                    {{ 'nav.mtla'|trans }}
                </a>
                <div class="navbar-dropdown">
                    <a class="navbar-item" href="/mtla/crowd/">
                        <i class="fa-solid fa-hand-holding-dollar"></i>
                        {{ 'nav.crowd'|trans }}
                    </a>
                    <hr class="navbar-divider">
                    <a class="navbar-item" href="/mtla/council">
                        {{ 'nav.council'|trans }}
                    </a>
                    <a class="navbar-item" href="/mtla/participants">
                        {{ 'nav.participants'|trans }}
                    </a>
                    <a class="navbar-item" href="/mtla/programs">
                        {{ 'nav.programs'|trans }}
                    </a>
                    {% if current_user.isImpactActivist %}
                    <hr class="navbar-divider">
                    <a class="navbar-item" href="/tools/mtla/recommend_verification">
                        {{ 'recommend_verification_page.title'|trans }}
                    </a>
                    <a class="navbar-item" href="/mtla/dm_report">
                        {{ 'nav.tools.mtla_dm_report'|trans }}
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="navbar-end">
            {% include 'navbar_search_dropdown.twig' with { navbar_search_item_classes: 'is-hidden-touch is-hidden-fullhd' } %}
            <div class="navbar-item is-hidden-touch is-hidden-desktop-only is-hidden-widescreen-only">
                {% include 'search_form.twig' with {
                    search_size: 'is-small',
                    search_classes: 'navbar-search-form',
                    search_button_label: false,
                    search_value: ''
                } %}
            </div>
            <a class="navbar-item" href="/preferences">
                <i class="fa-solid fa-gears"></i>
                {{ 'nav.preferences'|trans }}
            </a>
        </div>
    </div>
</nav>
{% set auto_current_account_notice = current_user.consumeAutoCurrentAccountNotice() %}
{% if auto_current_account_notice %}
<section class="hero is-small is-warning" id="auto-current-account-notice">
    <div class="hero-body">
        <div class="is-flex is-justify-content-space-between is-align-items-flex-start" style="gap: 1rem;">
            <div>
                <p class="title">{{ 'current_account_notice.title'|trans }}</p>
                <p class="block">
                    {{ 'current_account_notice.account_text'|trans }}
                    {{ include('account_link.twig', {data: auto_current_account_notice}, with_context = false) }}
                </p>
                <p class="block">
                    {{ 'current_account_notice.preferences_text'|trans }}
                    <a class="button is-warning is-light" href="/preferences">
                        <span class="icon"><i class="fa-solid fa-gears"></i></span>
                        <span>{{ 'nav.preferences'|trans }}</span>
                    </a>
                </p>
            </div>
            <button
                class="delete is-hidden"
                type="button"
                id="auto-current-account-notice-close"
                aria-label="{{ 'common.close'|trans }}"
            ></button>
        </div>
    </div>
</section>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const notice = document.getElementById('auto-current-account-notice');
        const close = document.getElementById('auto-current-account-notice-close');
        if (!notice || !close) {
            return;
        }
        close.classList.remove('is-hidden');
        close.addEventListener('click', function () {
            notice.remove();
        });
    });
</script>
{% endif %}
<section class="section">
    {% set is_wide_page = is_wide_page|default(false) %}
    {% if not is_wide_page %}
    <div class="container">
    {% endif %}
    <nav class="breadcrumb" aria-label="breadcrumbs">
        <ul>
            {% block breadcrumbs %}
            <li class="is-active"><a href="/" aria-current="page">{{ 'common.short_name'|trans }}</a></li>
            {% endblock %}
        </ul>
    </nav>

{% block content %}{% endblock %}
    {% if not is_wide_page %}
    </div>
    {% endif %}
</section>

<div class="footer">
    2024. Proudly developed by <a href="https://monte.wiki/ru/Соз">Soz</a> from <a href="https://mtla.me/">Montelibero Association</a>.
</div>
</body>
</html>
