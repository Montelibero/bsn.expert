{% extends "page.twig" %}

{% block title %}{{ 'recommend_verification_page.title'|trans }} — MTLA{% endblock %}

{% block breadcrumbs %}
    <li><a href="/" aria-current="page">BSN</a></li>
    <li><a href="/tools" aria-current="page">{{ 'nav.tools.title'|trans }}</a></li>
    <li class="is-active"><a href="#" aria-current="page">{{ 'recommend_verification_page.title'|trans }}</a></li>
{% endblock %}

{% block content %}
    <h1 class="title">{{ 'recommend_verification_page.title'|trans }}</h1>

    <div class="content block">
        <p>{{ 'recommend_verification_page.intro'|trans }}</p>
        <p>
            {{ 'recommend_verification_page.recommend_tag'|trans }}
            <a href="/tags/RecommendForVerification">RecommendForVerification</a>
        </p>
        <p>
            {{ 'recommend_verification_page.regulation'|trans }}
            <a href="https://docs.mtla.me/VerificationByRecommendationRegulation/VerificationByRecommendationRegulation.ru.html">VerificationByRecommendationRegulation</a>
        </p>
    </div>

    {% if candidates %}
        <h2 class="title is-5">{{ 'recommend_verification_page.candidates'|trans }}</h2>
        <ul class="block">
            {% for item in candidates %}
                <li>
                    {{ include('account_link.twig', {data: item}, with_context = false) }}
                    {% if item.accounts %}
                        <div style="margin: 0.25rem 0 1rem 1.25rem;">
                            <div class="is-size-7 has-text-grey">{{ 'recommend_verification_page.recommenders'|trans }}</div>
                            <ul>
                                {% for nested_item in item.accounts %}
                                    <li>{{ include('account_link.twig', {data: nested_item}, with_context = false) }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {% if verified %}
        <h2 class="title is-5">{{ 'recommend_verification_page.verified'|trans }}</h2>
        <ul class="block">
            {% for item in verified %}
                <li>
                    {{ include('account_link.twig', {data: item}, with_context = false) }}
                    {% if item.accounts %}
                        <div style="margin: 0.25rem 0 1rem 1.25rem;">
                            <div class="is-size-7 has-text-grey">{{ 'recommend_verification_page.recommenders'|trans }}</div>
                            <ul>
                                {% for nested_item in item.accounts %}
                                    <li>{{ include('account_link.twig', {data: nested_item}, with_context = false) }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {% if lost %}
        <h2 class="title is-5">{{ 'recommend_verification_page.lost'|trans }}</h2>
        <ul class="block">
            {% for item in lost %}
                <li>
                    {{ include('account_link.twig', {data: item}, with_context = false) }}
                    {% if item.accounts %}
                        <div style="margin: 0.25rem 0 1rem 1.25rem;">
                            <div class="is-size-7 has-text-grey">{{ 'recommend_verification_page.recommenders'|trans }}</div>
                            <ul>
                                {% for nested_item in item.accounts %}
                                    <li>{{ include('account_link.twig', {data: nested_item}, with_context = false) }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}

    {% if overflow_recommenders %}
        <h2 class="title is-5">{{ 'recommend_verification_page.overflow'|trans }}</h2>
        <ul class="block">
            {% for item in overflow_recommenders %}
                <li>
                    {{ include('account_link.twig', {data: item}, with_context = false) }}
                    {% if item.accounts %}
                        <div style="margin: 0.25rem 0 1rem 1.25rem;">
                            <div class="is-size-7 has-text-grey">{{ 'recommend_verification_page.recommended'|trans }}</div>
                            <ul>
                                {% for nested_item in item.accounts %}
                                    <li>{{ include('account_link.twig', {data: nested_item}, with_context = false) }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    {% endif %}
{% endblock %}
