<form method="post" action="/sign" target="_blank" class="block">
    <input type="hidden" name="xdr" value="{{ xdr }}">
    <input type="hidden" name="uri" value="{{ uri }}">
    <input type="hidden" name="description" value="{{ description }}">
    <input type="hidden" name="sign" value="{{ sign }}">
<div class="buttons">
    <button type="submit" name="action" value="qr" formtarget="_self" class="button js-signing-toggle" data-signing-toggle="qr" aria-expanded="false">
        <span class="icon"><i class="fa-solid fa-qrcode"></i></span>
        <span>QR</span>
    </button>

    <a href="{{ uri }}" class="button is-primary">
        <span class="icon"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
        <span>{{ 'editor.sign.sep_07_button_name'|trans }}</span>
    </a>

    <button type="submit" name="action" value="mmwb" class="button is-link">
        <span class="icon"><i class="fa-brands fa-telegram"></i></span>
        <span>@MyMTLWalletBot (MTL Wallet)</span>
    </button>

    {% if xdr %}
    <a href="https://eurmtl.me/uri?xdr={{ xdr|url_encode }}" target="_blank" class="button is-dark">
            <span class="icon">
                <i class="fa-solid fa-key"></i>
            </span>
        <span>Sign by secret key</span>
    </a>
    {% endif %}

    {% if xdr %}
        <button
            type="submit"
            name="action"
            value="eurmtl"
            class="button is-link"
            {% if not can_collect_multisig %}disabled title="{{ 'editor.sign.collect_multisig_disabled_title'|trans }}"{% endif %}
        >
            <span class="icon"><i class="fa-solid fa-signature"></i></span>
            <span>{{ 'editor.sign.collect_multisig_button_name'|trans }}</span>
        </button>
    {% endif %}

    {% if xdr %}
        <button type="submit" name="action" value="xdr" formtarget="_self" class="button js-signing-toggle" data-signing-toggle="xdr" aria-expanded="false">
            <span class="icon"><i class="fa-solid fa-file-code"></i></span>
            <span>XDR</span>
        </button>
    {% endif %}
</div>

<div class="signing-collapsible" data-signing-panel="qr">
    {{ include('signing_content.twig', {signing_view: 'qr'}) }}
</div>

{% if xdr %}
<div class="signing-collapsible" data-signing-panel="xdr">
    {{ include('signing_content.twig', {signing_view: 'xdr'}) }}
</div>
{% endif %}
</form>
