{% extends "page.twig" %}

{% block title %}{{ code }} — {{ 'nav.tokens'|trans }}{% endblock %}

{% block breadcrumbs %}
        <li><a href="/" aria-current="page">BSN</a></li>
        <li><a href="/tokens/" aria-current="page">{{ 'nav.tokens'|trans }}</a></li>
        <li class="is-active"><a href="#" aria-current="page">{{ code }}</a></li>
{% endblock %}

{% block content %}
<h1 class="title">{{ code }}, {{ include('account_link.twig', {data: issuer}, with_context = false) }}</h1>
<h1 class="subtitle">
        <span class="stellar_address is-family-monospace">{{ code }}</span>-<span class="stellar_address is-family-monospace">{{ issuer.id }}</span><br>
</h1>

<div class="is-flex is-flex-wrap-wrap is-align-items-center">
    <div class="is-flex is-flex-wrap-wrap is-align-items-center mb-2">
        <a class="button is-small is-primary is-outlined mr-2" href="{{ open_trustline_url }}">
            <span class="icon"><i class="fa-solid fa-link"></i></span>
            <span>{{ 'token_page.add_trustline.header'|trans }}</span>
        </a>
    </div>

    <div class="dropdown is-hoverable ml-auto mb-2 is-hidden-mobile">
        <div class="dropdown-trigger">
            <button class="button is-small" type="button" aria-haspopup="true" aria-controls="token-alternative-viewers-desktop">
                <span>{{ 'account_page.alternatives'|trans }}</span>
                <span class="icon is-small"><i class="fa-solid fa-angle-down" aria-hidden="true"></i></span>
            </button>
        </div>
        <div class="dropdown-menu is-right" id="token-alternative-viewers-desktop" role="menu">
            <div class="dropdown-content">
                <a class="dropdown-item" href="https://viewer.eurmtl.me/asset/{{ code }}-{{ issuer.id }}">Eurmtl.me</a>
                <a class="dropdown-item" href="https://lore.mtlprog.xyz/tokens/{{ issuer.id }}/{{ code }}">Lore</a>
                <hr class="dropdown-divider">
                <a class="dropdown-item" href="https://stellar.expert/explorer/public/asset/{{ code }}-{{ issuer.id }}">Stellar.Expert</a>
                <a class="dropdown-item" href="https://scopuly.com/trade/{{ code }}-XLM/{{ issuer.id }}/native">Scopuly</a>
            </div>
        </div>
    </div>
</div>

<div class="dropdown is-hoverable is-hidden-tablet mb-4">
    <div class="dropdown-trigger">
        <button class="button is-small" type="button" aria-haspopup="true" aria-controls="token-alternative-viewers-mobile">
            <span>{{ 'account_page.alternatives'|trans }}</span>
            <span class="icon is-small"><i class="fa-solid fa-angle-down" aria-hidden="true"></i></span>
        </button>
    </div>
    <div class="dropdown-menu" id="token-alternative-viewers-mobile" role="menu">
        <div class="dropdown-content">
            <a class="dropdown-item" href="https://viewer.eurmtl.me/asset/{{ code }}-{{ issuer.id }}">Eurmtl.me</a>
            <a class="dropdown-item" href="https://lore.mtlprog.xyz/tokens/{{ issuer.id }}/{{ code }}">Lore</a>
            <hr class="dropdown-divider">
            <a class="dropdown-item" href="https://stellar.expert/explorer/public/asset/{{ code }}-{{ issuer.id }}">Stellar.Expert</a>
            <a class="dropdown-item" href="https://scopuly.com/trade/{{ code }}-XLM/{{ issuer.id }}/native">Scopuly</a>
        </div>
    </div>
</div>

<style>
        dd {
                margin-left: 2rem;
        }
</style>
<div class="columns">
    <div class="column">
        <dl class="box">
            {% if category %}
                <dt class="title is-4">{{ 'token_page.category'|trans }}</dt>
                <dd class="subtitle is-4">
                    <a href="/tokens/#category_{{ category }}">{{ category_name }}</a>
                </dd>
            {% endif %}
            {% if offer_document %}
                <dt class="title is-4">{{ 'token_page.offer_document'|trans }}</dt>
                <dd class="subtitle is-4">
                    <a href="/documents/{{ offer_document.hash }}/" class="is-family-monospace">{{ offer_document.hash_short }}</a>
                </dd>
            {% endif %}
            {% if offer_link %}
                <dt class="title is-4">{{ 'token_page.offer_link'|trans }}</dt>
                <dd class="subtitle is-4">
                    <a href="{{ offer_link }}">{{ offer_link }}</a>
                </dd>
            {% endif %}
            <dt class="title is-4">{{ 'token_page.holders_count'|trans }}</dt>
            <dd class="subtitle is-4">
                {{ holders_count }}
            </dd>
            <dt class="title is-4">{{ 'token_page.issued'|trans }}</dt>
            <dd class="subtitle is-4">
                {{ issued }}
            </dd>
        </dl>
    </div>

    {% if token_image %}
        <div class="column is-narrow">
            <div class="box">
                <figure class="image is-128x128">
                    <img src="{{ token_image }}" alt="{{ code }}">
                </figure>
            </div>
        </div>
    {% endif %}
</div>

{% if offer_document.text %}
    <div class="message token-offer-text" data-token-offer>
        <div class="message-header">
            {{ 'token_page.offer_text.header'|trans }}
        </div>
        <div class="message-body">
            <div class="token-offer-text-frame" data-token-offer-frame>
                {% if offer_document.text_html %}
                    <div class="content">{{ offer_document.text_html|raw }}</div>
                {% else %}
                    <div class="original_text token-offer-original-text">{{ offer_document.text }}</div>
                {% endif %}
            </div>
            <p class="block token-offer-open-full-link">
                <a href="/documents/{{ offer_document.hash }}/">{{ 'token_page.offer_text.open_full'|trans }}</a>
            </p>
            <p class="block token-offer-expand-control is-hidden" data-token-offer-expand-control>
                <button type="button" class="pseudo-link" data-token-offer-expand>
                    {{ 'token_page.offer_text.expand'|trans }}
                </button>
            </p>
        </div>
    </div>
{% endif %}

{% if show_add_trustline_form %}
    <div class="box">
        <h2 class="title">{{ 'token_page.add_trustline.header'|trans }}</h2>
        <p class="block">{{ 'token_page.add_trustline.description'|trans }}</p>
        {{ add_trustline_form|raw }}
    </div>
{% endif %}

{% if holders %}
    <script>
        $(function () {
            $(".table").tablesorter();
        });
    </script>
    <h2 class="title">{{ 'token_page.holders.header'|trans }}</h2>
    <table class="table"  data-sortlist="[[1,1],[0,0]]">
        <thead>
        <tr>
            <th>{{ 'token_page.holders.account'|trans }}</th>
            <th class="has-text-right">{{ 'token_page.holders.amount'|trans }}</th>
        </tr>
        </thead>
        <tbody>
        {% for holder in holders %}
            <tr>
                <td>{{ include('account_link.twig', {data: holder.account}, with_context = false) }}</td>
                <td data-sort-value="{{ holder.amount_value }}" class="has-text-right">{% include 'amount.twig' with {value: holder.amount} only %}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}

{% endblock %}
