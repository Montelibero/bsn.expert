{% extends "page.twig" %}

{% block title %}{{ project.name }}{% endblock %}

{% block breadcrumbs %}
    <li><a href="/">{{ 'common.short_name'|trans }}</a></li>
    <li><a href="/mtla/" aria-current="page">{{ 'nav.mtla'|trans }}</a></li>
    <li><a href="/mtla/crowd/">{{ 'crowd_page.title'|trans }}</a></li>
    <li class="is-active"><a href="/mtla/crowd/{{ project.code }}" aria-current="page">{{ project.code }}</a></li>
{% endblock %}

{% macro amount(value) %}
    {{ include('amount.twig', {value: value}, with_context = false) }}
{% endmacro %}

{% macro integer(value) %}
    {{ value|round(0, 'common')|number_format(0, '.', ' ') }}
{% endmacro %}

{% macro status(status) %}
    {% set classes = {
        completed: 'is-success',
        funded: 'is-success',
        active: 'is-info',
        expired: 'is-warning',
        canceled: 'is-dark',
        error: 'is-danger',
        closed: 'is-dark'
    } %}
    {% set icons = {
        completed: 'fa-check',
        funded: 'fa-check',
        active: 'fa-hand-holding-dollar',
        expired: 'fa-triangle-exclamation',
        canceled: 'fa-xmark',
        error: 'fa-triangle-exclamation',
        closed: 'fa-check'
    } %}
    <span class="tag {{ classes[status] ?? 'is-dark' }}">
        <span class="icon is-small"><i class="fa-solid {{ icons[status] ?? 'fa-circle-info' }}" aria-hidden="true"></i></span>
        <span>{{ ('crowd_page.status.' ~ status)|trans }}</span>
    </span>
{% endmacro %}

{% import _self as ui %}

{% block content %}
    <div class="is-flex is-justify-content-space-between is-align-items-flex-start mb-4" style="gap: 1rem;">
        <div>
            <h1 class="title mb-2">{{ project.name }}</h1>
            <div class="tags">
                {{ ui.status(project.status) }}
                <span class="tag is-info">{{ project.code }}</span>
            </div>
        </div>
    </div>

    {% if can_manage %}
        <div class="is-flex is-flex-wrap-wrap is-align-items-center mb-4">
            {% if admin_actions.primary %}
                <a class="button is-small {{ admin_actions.primary.class }} mr-2 mb-2" href="{{ admin_actions.primary.url }}">
                    <span class="icon"><i class="fa-solid {{ admin_actions.primary.icon }}" aria-hidden="true"></i></span>
                    <span>{{ admin_actions.primary.label|trans }}</span>
                </a>
            {% endif %}

            <div class="dropdown is-hoverable mr-2 mb-2">
                <div class="dropdown-trigger">
                    <button class="button is-small is-info is-outlined" type="button" aria-haspopup="true" aria-controls="crowd-project-actions-menu">
                        <span>{{ 'crowd_page.admin.actions'|trans }}</span>
                        <span class="icon is-small"><i class="fa-solid fa-angle-down" aria-hidden="true"></i></span>
                    </button>
                </div>
                <div class="dropdown-menu" id="crowd-project-actions-menu" role="menu">
                    <div class="dropdown-content">
                        {% for item in admin_actions.menu %}
                            <a class="dropdown-item" href="{{ item.url }}">
                                <span class="icon"><i class="fa-solid {{ item.icon }}" aria-hidden="true"></i></span>
                                <span>{{ item.label|trans }}</span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}

    {% if project.warning %}
        <div class="notification is-warning">
            {{ project.warning }}
        </div>
    {% endif %}

    {% set show_support = not project.is_closed and project.remaining_amount + 0 > 0 %}

    {% if donation %}
        {% if donation.errors %}
            <div class="notification is-danger">
                {% for error in donation.errors %}
                    <p>{{ error.key|trans(error.params) }}</p>
                {% endfor %}
            </div>
        {% elseif donation.payment %}
            <p class="block">
                {% if donation.payment.mode == 'direct' %}
                    {{ 'crowd_page.support.payment_direct'|trans }}
                {% else %}
                    {{ 'crowd_page.support.payment_path'|trans }}
                {% endif %}
                {{ include('token_link.twig', {
                    token: donation.payment.token,
                    amount: donation.payment.mode == 'direct' ? donation.amount + 0 : donation.payment.send_max + 0
                }, with_context = false) }}
            </p>
        {% endif %}

        {% if donation_signing_form %}
            {{ donation_signing_form|raw }}
        {% endif %}
    {% endif %}

    <div class="columns is-multiline is-flex-direction-row-reverse">
        <div class="column is-5-tablet is-4-widescreen">
            {% set preset_amounts = [5, 10, 50, 100] %}
            {% set support_input_amount = project.remaining_amount + 0 < 500 ? project.remaining_amount + 0 : 500 %}
            {% set support_query_prefix = current_account_param ? '?current_account=' ~ current_account_param|url_encode ~ '&amount=' : '?amount=' %}
            <div class="box">
                {% if show_support %}
                    <h2 class="title is-5">{{ 'crowd_page.support.title'|trans }}</h2>
                    <div class="field is-grouped is-grouped-multiline mb-3 block">
                        {% for amount in preset_amounts %}
                            {% if amount <= project.remaining_amount + 0 %}
                                <div class="control">
                                    <a class="button is-primary" href="/mtla/crowd/{{ project.code }}{{ support_query_prefix }}{{ amount }}">{{ amount }}</a>
                                </div>
                            {% endif %}
                        {% endfor %}
                        <div class="control">
                            <form class="field has-addons" action="/mtla/crowd/{{ project.code }}" method="get">
                                {% if current_account_param %}
                                    <input type="hidden" name="current_account" value="{{ current_account_param }}">
                                {% endif %}
                                <div class="control">
                                    <input class="input" name="amount" type="number" min="0" max="{{ project.remaining_amount }}" step="1" value="{{ support_input_amount }}">
                                </div>
                                <div class="control">
                                    <button class="button is-primary" type="submit">{{ 'crowd_page.support.custom_amount'|trans }}</button>
                                </div>
                            </form>
                        </div>
                    </div>
                    <p class="block">{{ 'crowd_page.support.notice'|trans({'%code%': project.mtlcrowd_token.code}) }}</p>
                {% else %}
                    <h2 class="title is-5">{{ 'crowd_page.project.details'|trans }}</h2>
                {% endif %}

                <progress class="progress {{ project.status != 'canceled' ? 'is-primary' : '' }} mb-2" value="{{ project.progress_percent }}" max="100">
                    {{ project.progress_percent|round(0, 'common') }}%
                </progress>
                <div class="is-flex is-justify-content-space-between is-flex-wrap-wrap block">
                    <span>
                        {% if project.target_amount + 0 > 0 and project.funded_amount + 0 >= project.target_amount + 0 %}
                            {{ ui.integer(project.funded_amount) }}
                        {% else %}
                            {{ ui.integer(project.funded_amount) }} / {{ ui.integer(project.target_amount) }}
                        {% endif %}
                        {{ include('token_link.twig', {token: project.mtlcrowd_token}, with_context = false) }}
                    </span>
                    <span class="has-text-grey">{{ project.progress_percent|round(0, 'common') }}%</span>
                </div>
                <table class="table is-fullwidth">
                    <tbody>
                    <tr>
                        <th>{{ 'crowd_page.project.deadline'|trans }}</th>
                        <td>{{ project.deadline ?: 'common.not_available'|trans }}</td>
                    </tr>
                    {% if project.remaining_amount + 0 > 0 %}
                        <tr>
                            <th>{{ 'crowd_page.project.remaining'|trans }}</th>
                            <td>
                                {{ ui.integer(project.remaining_amount) }}
                                {{ include('token_link.twig', {token: project.mtlcrowd_token}, with_context = false) }}
                            </td>
                        </tr>
                    {% endif %}
                    <tr>
                        <th>{{ 'crowd_page.project.project_account'|trans }}</th>
                        <td>
                            {% if project.project_account %}
                                {{ include('account_link.twig', {data: project.project_account}, with_context = false) }}
                            {% else %}
                                {{ 'common.not_available'|trans }}
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th>{{ 'crowd_page.project.contact_account'|trans }}</th>
                        <td>
                            {% if project.contact_account %}
                                {{ include('account_link.twig', {data: project.contact_account}, with_context = false) }}
                            {% else %}
                                {{ 'common.not_available'|trans }}
                            {% endif %}
                        </td>
                    </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="column is-7-tablet is-8-widescreen">
            <p class="subtitle">{{ project.description }}</p>

            {% if project.full_description_html %}
                <div class="content">
                    {{ project.full_description_html|raw }}
                </div>
            {% endif %}
        </div>
    </div>

    <h2 class="title is-4">{{ 'crowd_page.project.supporters'|trans }}</h2>
    <div class="table-container">
        <table class="table is-fullwidth is-striped is-hoverable">
            <thead>
            <tr>
                <th>{{ 'crowd_page.project.supporter'|trans }}</th>
                <th class="has-text-right">{{ 'crowd_page.project.amount'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for supporter in project.supporters %}
                <tr>
                    <td>{{ include('account_link.twig', {data: supporter.account}, with_context = false) }}</td>
                    <td class="has-text-right">{{ ui.integer(supporter.amount) }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="2" class="has-text-grey">{{ 'crowd_page.project.no_supporters'|trans }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if not project.is_closed %}
        {% include 'crowd_snapshot_box.twig' with {
            snapshot: snapshot,
            refresh: refresh
        } only %}
    {% endif %}
{% endblock %}
